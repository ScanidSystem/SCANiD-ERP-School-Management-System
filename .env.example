# API configuration
# API Configuration
# Use /api for unified server (Vite + Express on same port)
VITE_API_BASE_URL=/api

# For local development with split backend (.NET on separate port), use:
# VITE_API_BASE_URL=http://localhost:5000/api
# For unified development or production, leave as /api
VITE_API_BASE_URL=/api

# Server port (App and API)
# AI Studio requires port 3000
PORT=3000
