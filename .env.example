# API Configuration
# For production server with subdirectory (e.g. https://domain.com/SubDir/api)
VITE_API_BASE_URL=/SCANiD_ERP_API/api

# For local dev with separate .NET backend:
# VITE_API_BASE_URL=/api

# Server configuration (AI Studio uses port 3000)
PORT=3000

# Gemini API Key (Server-side only)
GEMINI_API_KEY=
