# API Configuration
# For local development with split backend, set this to http://localhost:5000/api
# For production server with subdirectory (e.g. https://domain.com/SubDir/api)
VITE_API_BASE_URL=http://localhost:5000/api

# Server port (App and API)
# AI Studio requires port 3000, but local dev uses 5000
PORT=5000

# Gemini API Key (Server-side only)
GEMINI_API_KEY=
