# API Configuration
# For local dev with separate .NET backend:
# VITE_API_BASE_URL=http://localhost:5000/api
# Or use the Vite proxy (configured in vite.config.ts) and keep this as /api
VITE_API_BASE_URL=/api

# Server configuration (AI Studio uses port 3000)
PORT=3000

# Gemini API Key (Server-side only)
GEMINI_API_KEY=
